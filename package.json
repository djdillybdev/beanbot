{
  "name": "beanbot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Discord bot for personal task and calendar management",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "sync:obsidian": "bun run src/scripts/obsidian-sync.ts",
    "test": "bun test",
    "register:commands": "bun run src/scripts/register-commands.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/scripts/migrate.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "discord.js": "^14.22.1",
    "drizzle-orm": "^0.44.5",
    "express": "^5.1.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/bun": "^1.2.22",
    "@types/express": "^5.0.3",
    "drizzle-kit": "^0.31.4",
    "typescript": "^5.9.2"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
